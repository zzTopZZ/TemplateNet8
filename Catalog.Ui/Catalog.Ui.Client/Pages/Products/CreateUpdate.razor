@page "/product/create"
@page "/product/update/{Id:int}"

@{
    var textTitle = Id > 0 ? "Edit" : "Add";
}

<h3>@textTitle Product</h3>

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div class="card">

                <div class="card-header">@textTitle Product</div>

                <div class="card-body">

                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert @(IsError ? "alert-danger" : "alert-success")">
                            @StatusMessage
                        </div>
                    }

                    <EditForm Model="ProductModel" OnValidSubmit="HandleSaveAsync" FormName="CreateUpdateProduct">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <!-- NAME -->
                        <div class="form-group">
                            <label class="form-label">Name</label>
                            <InputText @bind-Value="ProductModel.Name" @bind-Value:event="oninput" class="form-control" />
                            <ValidationMessage For="() => ProductModel.Name" />
                        </div>

                        <!-- PRICE -->
                        <div class="form-group">
                            <label class="form-label">Price</label>
                            <InputNumber id="product-price-input" @bind-Value="ProductModel.Price" @bind-Value:event="oninput" class="form-control" />
                            <ValidationMessage For="() => ProductModel.Price" />
                        </div>

                        <!-- CATEGORY -->
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <InputSelect @bind-Value="ProductModel.CategoryId" @bind-Value:event="onchange" class="form-control">
                                <option value="">Select a category</option>
                                @foreach (var category in Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => ProductModel.CategoryId" />
                        </div>

                        <!-- BUTTONS -->
                        <div class="m-3 p-3">
                            <button type="button" class="btn btn-outline-primary" disabled="@(IsSaving)" @onclick="OnSaveClicked">@(IsSaving ? "Saving..." : "Save")</button>

                            <button type="button" class="btn btn-secondary ms-2" @onclick="() => ShowPayload = !ShowPayload">@(ShowPayload ? "Ocultar payload" : "Mostrar payload")</button>

                            <a href="/products" class="btn btn-outline-warning ms-2">Cancelar</a>
                        </div>

                    </EditForm>

                    <!-- DEBUG -->
                    @if (ShowPayload)
                    {
                        <div class="mt-3">
                            <label class="form-label">Payload (debug)</label>
                            <pre style="background:#f8f9fa;padding:10px;border-radius:4px;"> 
                                    @GetDebugPayload()
                                        </pre>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>